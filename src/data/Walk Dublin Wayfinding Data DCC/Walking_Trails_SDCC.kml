		<SimpleData name="FID">4</SimpleData>
		<SimpleData name="OBJECTID">2002</SimpleData>
		<SimpleData name="County">South Dublin</SimpleData>
		<SimpleData name="TrailName">Cruagh - Sli na Slainte</SimpleData>
		<SimpleData name="Category">WalkingHikingTrails</SimpleData>
		<SimpleData name="Type">Coillte Recreation Trails</SimpleData>
		<SimpleData name="Length">5 kms</SimpleData>
		<SimpleData name="Grade">Moderate</SimpleData>
		<SimpleData name="Climb">100 m</SimpleData>
